#pragma once

// このファイルを include/secrets.h にコピーして、自分の環境の値を設定してください。
//   cp include/secrets.h.example include/secrets.h
// secrets.h は .gitignore 済みなので git にはコミットされません。

#define WIFI_SSID "your-wifi-ssid"
#define WIFI_PASS "your-wifi-password"

// NTP / タイムゾーン設定（日本標準時 = UTC+9, サマータイムなし）
#define NTP_TZ_OFFSET_SEC (9 * 3600)
#define NTP_DST_OFFSET_SEC 0
#define NTP_SERVER_1 "ntp.nict.jp"
#define NTP_SERVER_2 "time.google.com"
#define NTP_SERVER_3 "pool.ntp.org"

// Datadog アラートサイレン用 Cloudflare Worker（cloud/README.md 参照）
// デプロイ後の Worker URL と、wrangler secret put DEVICE_TOKEN で設定した値を入れる
#define ALERT_WORKER_URL "https://m5deck-alert.<your-subdomain>.workers.dev"
#define ALERT_DEVICE_TOKEN "your-device-token"
